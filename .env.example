# docker-compose.yml が読み込む環境変数のテンプレート。
# コピーして .env を作成し、実際の値を設定すること（.env はコミットしない）。

# --- PostgreSQL ---
POSTGRES_USER=stockapp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=stockapp

# --- AI連携（既存 backend/.env と同様） ---
# カンマ区切りで複数キー指定可（ai_service.py の get_keys() 参照）
GEMINI_API_KEYS=

# --- 開示情報（フェーズ3） ---
EDINET_API_KEY=

# --- 公開ホスト名（DuckDNS） ---
# 例: stockapp.duckdns.org
DUCKDNS_HOSTNAME=

# --- 自前認証 ---
# ログイン時に照合する共有パスワード
APP_PASSWORD=
# セッションCookie署名用のランダムな秘密文字列（例: python -c "import secrets; print(secrets.token_hex(32))"）
SESSION_SECRET=

# --- CORS ---
# フロントエンドの本番URL（例: https://your-project.pages.dev）。複数ある場合はカンマ区切り
FRONTEND_ORIGIN=
